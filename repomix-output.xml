                  </td>
                  
                  {/* 💡 (ลบช่องว่างบรรทัดในโค้ดตรงนี้ออก เพื่อให้ดูเป็นระเบียบขึ้นได้เลยครับ) */}

                  <td className="px-6 py-4 whitespace-nowrap text-sm">
                    {item.isPasswordSet ? (
                      <span className="text-emerald-600 dark:text-emerald-400 font-medium">สร้างแล้ว</span>
